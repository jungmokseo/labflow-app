{
  "name": "labflow-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && prisma db push --skip-generate && tsc",
    "build:deploy": "prisma generate && prisma migrate deploy && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "backfill-embeddings": "tsx src/scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/sensible": "^6.0.3",
    "@google/generative-ai": "^0.21.0",
    "@notionhq/client": "^2.3.0",
    "@prisma/client": "^6.4.1",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  }
}
