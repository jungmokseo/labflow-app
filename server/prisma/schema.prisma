// LabFlow API — Prisma Schema for Supabase PostgreSQL
// Run: npx prisma db push (개발) or npx prisma migrate dev (프로덕션)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 사용자 (Clerk 연동) ────────────────────────────────
model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique @map("clerk_id")
  email       String    @unique
  name        String?
  labName     String?   @map("lab_name")
  plan        Plan      @default(BASIC)
  credits     Int       @default(100) // AI 분류 크레딧
  metadata    Json?     @default("{}")  // 확장용 JSONB
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  captures        Capture[]
  gmailTokens     GmailToken[]
  emailProfile    EmailProfile?
  meetings        Meeting[]
  preferences     UserPreference[]
  lab             Lab?
  channels        Channel[]
  memos           Memo[]

  @@map("users")
}

enum Plan {
  BASIC
  PRO
  MAX
}

// ── 캡처 (핵심 데이터) ─────────────────────────────────
model Capture {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  labId       String?         @map("lab_id")       // Lab 소속 (선택적)
  content     String          // 원본 텍스트
  summary     String          // AI 요약
  category    CaptureCategory @default(MEMO)
  tags        String[]        // AI 태그 배열
  priority    Priority        @default(MEDIUM)
  confidence  Float?          // AI 분류 신뢰도 0~1
  actionDate  DateTime?       @map("action_date")
  modelUsed   String?         @map("model_used") // local | gemini-flash
  completed   Boolean         @default(false)
  completedAt DateTime?       @map("completed_at")
  sourceType  String          @default("text") @map("source_type") // text | voice
  rawInput    String?         @map("raw_input")  // 원본 음성 텍스트 (STT 결과)
  status      String          @default("active") // active | completed | archived
  reviewed    Boolean         @default(false)  // 확인 여부 (자동 캡처 = false)
  metadata    Json?           @default("{}")  // 확장용 JSONB
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab         Lab?            @relation(fields: [labId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, completed])
  @@index([labId, category])
  @@index([labId, status])
  @@index([userId, reviewed, status])
  @@map("captures")
}

enum CaptureCategory {
  IDEA
  TASK
  MEMO
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

// ── 회의 노트 ───────────────────────────────────────────
model Meeting {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  title          String
  transcription  String?  // Gemini STT 전사 결과
  summary        String?  // Sonnet 구조화 요약 (JSON 또는 마크다운)
  agenda         String[] // 📋 안건 목록
  discussions    String?  // 📝 논의 내용 (소주제별, JSON 문자열)
  actionItems    String[] @map("action_items") // ✅ 액션 아이템
  nextSteps      String[] @map("next_steps")   // 📌 다음 할 일
  duration       Int?     // 녹음 시간 (초)
  modelUsed      String?  @map("model_used")
  metadata       Json?    @default("{}")  // 확장용 JSONB
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("meetings")
}

// ── Gmail 인증 토큰 (멀티 계정 지원) ───────────────────────
model GmailToken {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  email        String    @default("")                // Gmail 계정 주소
  label        String?                               // 표시 라벨 (예: "연세대", "링크솔루텍")
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  primary      Boolean   @default(false)             // 기본 계정 여부
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
  @@map("gmail_tokens")
}

// ── 이메일 프로필 (다계정 분류 설정 + T_last) ─────────────
model EmailProfile {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  classifyByGroup  Boolean   @default(false) @map("classify_by_group") // true: 기관별+성격별 이중 분류
  groups           Json      @default("[]") // [{ name, domains[], emoji }]
  lastBriefingAt   DateTime? @map("last_briefing_at") // T_last: 마지막 브리핑 시각
  excludePatterns  Json      @default("[]") // 제외 패턴: [{ field, pattern }]
  keywords         Json      @default("[]") // 중요도 상향 키워드 목록
  importanceRules  Json      @default("[]") @map("importance_rules") // [{ condition, action, description }]
  senderTimezones  Json      @default("[]") @map("sender_timezones") // [{ domains[], timezone, label }]
  timezone         String    @default("America/New_York") // 기본 시간대

  // ── 동적 브리핑 컨텍스트 (자동 학습 + 사용자 입력) ──
  projectContext   Json      @default("{}") @map("project_context")
  // { role, organization, location, researchAreas[] }

  keyPeople        Json      @default("[]") @map("key_people")
  // [{ name, role, email?, org, relationship }] — 핵심 인물 (자동 축적 + 수동 입력)

  activeThreads    Json      @default("[]") @map("active_threads")
  // [{ topic, status, lastUpdate, parties[] }] — 추적 중인 건

  briefingStyle    Json      @default("{}") @map("briefing_style")
  // { excludePatterns: string[], customInstructions: string }

  learnedPatterns  Json      @default("{}") @map("learned_patterns")
  // AI가 브리핑 반복 중 학습: { senderMap: {email→{name,org}}, frequentTopics[] }

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_profiles")
}

// ── RAG 벡터 임베딩 (pgvector) ─────────────────────────────
model MemoEmbedding {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceType  String   @map("source_type")
  sourceId    String   @map("source_id")
  labId       String?  @map("lab_id")
  userId      String?  @map("user_id")
  title       String?
  chunkIndex  Int      @default(0) @map("chunk_index")
  chunkText   String   @map("chunk_text")
  contentHash String   @map("content_hash")
  embedding   Unsupported("vector(1536)")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@unique([sourceId, sourceType, chunkIndex])
  @@index([labId, sourceType])
  @@index([userId])
  @@map("memo_embeddings")
}

// ── 지식 그래프: 노드 (엔티티) ──────────────────────────────
model KnowledgeNode {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")       // 사용자 소속 (multi-tenant)
  entityType  String   @map("entity_type")   // person, project, paper, term, equipment, journal, institution, topic
  entityId    String?  @map("entity_id")     // 기존 DB 레코드 연결 (User.id, Meeting.id 등)
  name        String                          // 엔티티 표시명
  metadata    Json?                           // 추가 속성 (role, affiliation 등)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  outEdges    KnowledgeEdge[] @relation("fromNode")
  inEdges     KnowledgeEdge[] @relation("toNode")

  @@unique([userId, entityType, name])
  @@index([userId])
  @@index([userId, entityType])
  @@index([entityId])
  @@map("knowledge_nodes")
}

// ── 지식 그래프: 엣지 (관계) ──────────────────────────────
model KnowledgeEdge {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")        // 데이터 격리 (multi-tenant)
  fromNodeId  String   @map("from_node_id")
  toNodeId    String   @map("to_node_id")
  relation    String   // participates_in, authored, uses_term, published_in, supervises, collaborates_with, cited_by, related_to, discussed_in, mentioned_in
  weight      Float    @default(1.0)          // 관계 강도 (언급 횟수에 비례)
  source      String                          // chat, meeting, email, paper_alert, onboarding, manual, seed
  evidence    String?                         // 근거 텍스트 (원문 발췌)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  fromNode    KnowledgeNode @relation("fromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode      KnowledgeNode @relation("toNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, relation])
  @@index([userId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([source])
  @@map("knowledge_edges")
}

// ── 사용자 기능별 선호도 (암묵적 피드백 학습) ──────────────
model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  featureType   String   @map("feature_type")   // "email" | "memo" | "meeting" | "general"
  rules         Json     @default("{}")          // 기능별 학습된 규칙
  // email rules 예시: {"sender_priority": {}, "keyword_boost": [], "keyword_suppress": [], "response_mode": "summary_only"}
  version       Int      @default(1)
  snapshotData  Json?    @map("snapshot_data")   // Selective Reset 시 이전 상태 백업
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureType])
  @@index([userId])
  @@map("user_preferences")
}

// ── 연구실 프로필 ──────────────────────────────────────────
model Lab {
  id              String    @id @default(cuid())
  ownerId         String    @unique @map("owner_id")
  name            String
  institution     String?
  department      String?
  piName          String?   @map("pi_name")
  piEmail         String?   @map("pi_email")
  researchFields  String[]  @map("research_fields")
  researchThemes  Json?     @map("research_themes")  // [{name, keywords[], journals[]}]
  homepageUrl     String?   @map("homepage_url")
  acknowledgment  String?
  responseStyle   String?   @map("response_style")
  instructions    String?   // 사용자 지침 (claude.md 스타일, Brain 응답 시 항상 참조)
  onboardingDone  Boolean   @default(false) @map("onboarding_done")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members         LabMember[]
  projects        Project[]
  publications    Publication[]
  domainDict      DomainDict[]
  memos           Memo[]
  paperAlerts     PaperAlert[]
  captures        Capture[]

  @@map("labs")
}

// ── 연구실 멤버 ──────────────────────────────────────────
model LabMember {
  id            String        @id @default(cuid())
  labId         String        @map("lab_id")
  userId        String?       @map("user_id")       // Clerk 계정 연결 (로그인 시)
  name          String
  email         String?
  role          String        @default("학생")
  permission    LabPermission @default(VIEWER)       // 접근 권한
  team          String?                              // 팀 배정 (예: "LM팀", "Hydrogel팀")
  phone         String?
  active        Boolean       @default(true)
  confidence    Float         @default(1.0)
  metadata      Json?         @default("{}")
  accessCount   Int           @default(0) @map("access_count")
  lastVerified  DateTime?     @map("last_verified")
  lastAccessed  DateTime?     @map("last_accessed")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  lab           Lab           @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, active])
  @@index([userId])
  @@map("lab_members")
}

enum LabPermission {
  OWNER     // PI — 전체 관리 (설정, 멤버, 삭제)
  ADMIN     // 관리자 — 데이터 관리 (추가/수정, 멤버 초대)
  EDITOR    // 편집자 — 데이터 추가/수정 (미팅 노트, 캡처 등)
  VIEWER    // 열람자 — 읽기 전용 (브리핑 조회, 검색)
}

// ── 연구 프로젝트 ────────────────────────────────────────
model Project {
  id              String    @id @default(cuid())
  labId           String    @map("lab_id")
  name            String
  number          String?
  funder          String?
  period          String?
  pi              String?
  pm              String?
  acknowledgment  String?
  status          String    @default("active")
  confidence      Float     @default(1.0)
  metadata        Json?     @default("{}")
  accessCount     Int       @default(0) @map("access_count")
  lastVerified    DateTime? @map("last_verified")
  lastAccessed    DateTime? @map("last_accessed")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  lab             Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId])
  @@map("projects")
}

// ── 논문/출판물 ──────────────────────────────────────────
model Publication {
  id            String    @id @default(cuid())
  labId         String    @map("lab_id")
  title         String
  authors       String?
  journal       String?
  year          Int?
  doi           String?
  abstract      String?
  projectId     String?   @map("project_id")
  indexed       Boolean   @default(false)          // 벡터 임베딩 완료 여부
  nickname      String?                            // 별칭 (예: "핵심 논문 1번", "LM 논문")
  confidence    Float     @default(1.0)
  accessCount   Int       @default(0) @map("access_count")
  lastVerified  DateTime? @map("last_verified")
  lastAccessed  DateTime? @map("last_accessed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lab           Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, year])
  @@map("publications")
}

// ── 도메인 사전 (전문용어) ────────────────────────────────
model DomainDict {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  wrongForm   String   @map("wrong_form")
  correctForm String   @map("correct_form")
  category    String?
  autoAdded   Boolean  @default(false) @map("auto_added")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([labId, wrongForm])
  @@map("domain_dicts")
}

// ── 메모 ─────────────────────────────────────────────────
model Memo {
  id            String    @id @default(cuid())
  labId         String?   @map("lab_id")
  userId        String    @map("user_id")
  title         String?
  content       String
  tags          String[]
  source        String    @default("manual")
  shared        Boolean   @default(false)
  confidence    Float     @default(1.0)
  accessCount   Int       @default(0) @map("access_count")
  lastVerified  DateTime? @map("last_verified")
  lastAccessed  DateTime? @map("last_accessed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lab           Lab?      @relation(fields: [labId], references: [id], onDelete: SetNull)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([labId, createdAt(sort: Desc)])
  @@map("memos")
}

// ── 논문 알림 설정 ───────────────────────────────────────
model PaperAlert {
  id           String    @id @default(cuid())
  labId        String    @map("lab_id")
  keywords     String[]
  journals     String[]                          // built-in journal names
  customFeeds  Json?     @map("custom_feeds")    // [{name, rssUrl, publisher?}]
  schedule     String    @default("weekly")
  active       Boolean   @default(true)
  lastRunAt    DateTime? @map("last_run_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  lab         Lab              @relation(fields: [labId], references: [id], onDelete: Cascade)
  results     PaperAlertResult[]

  @@index([labId, active])
  @@map("paper_alerts")
}

// ── 논문 알림 결과 ───────────────────────────────────────
model PaperAlertResult {
  id          String    @id @default(cuid())
  alertId     String    @map("alert_id")
  title       String
  authors     String?
  journal     String?
  pubDate     DateTime? @map("pub_date")
  url         String?
  abstract    String?
  aiSummary   String?   @map("ai_summary")
  relevance   Float     @default(0.0)
  stars       Int       @default(0)             // ★ 1~3 relevance rating
  themes      String[]  @default([])            // matched theme names
  doi         String?
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  alert       PaperAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId, read])
  @@map("paper_alert_results")
}

// ── 대화 채널 (Brain 멀티레이어) ─────────────────────────
model Channel {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  type        String    // BRAIN, MEETING, PAPER, EMAIL
  tool        String?   // 사용된 도구 (general, email, papers, etc.) — 레거시, shadow로 대체
  name        String?
  pinned      Boolean   @default(false)
  archived    Boolean   @default(false)
  shadow      Boolean   @default(false)           // Shadow 세션 여부 (사용자에게 안 보임)
  shadowType  String?   @map("shadow_type")       // "email" | "calendar" | "knowledge"
  messageCount Int      @default(0) @map("message_count")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  summaries   ChannelSummary[]

  @@unique([userId, shadowType])
  @@index([userId, archived, lastMessageAt(sort: Desc)])
  @@index([userId, shadow])
  @@map("channels")
}

// ── 대화 메시지 ──────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")        // 데이터 격리 (multi-tenant)
  channelId   String   @map("channel_id")
  role        String   // user, assistant
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId, createdAt(sort: Desc)])
  @@map("messages")
}

// ── AI 비용 로그 ────────────────────────────────────────────
model AiCostLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  service   String                        // gemini-flash, claude-sonnet, openai-embedding, etc.
  cost      Float                         // USD 추정 비용
  intent    String?                       // brain intent (email_briefing, general_chat, etc.)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("ai_cost_logs")
}

// ── 채널 요약 ────────────────────────────────────────────
model ChannelSummary {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")       // 데이터 격리 (multi-tenant)
  channelId     String   @map("channel_id")
  summaryText   String   @map("summary_text")
  messageRange  String?  @map("message_range")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId, createdAt(sort: Desc)])
  @@map("channel_summaries")
}
